LOGIN_URL="https://example.com/login"
STATUS_URL="https://example.com/lock/status"
LOGIN_EMAIL="your-lock-email@example.com"

EMAIL_INPUT_SELECTOR="input[type='email']"
SEND_CODE_BUTTON_SELECTOR="button:has-text('Send code')"
OTP_INPUT_SELECTOR="input[name='otp']"
OTP_SUBMIT_BUTTON_SELECTOR="button:has-text('Verify')"
OTP_SUBMIT_METHOD="enter"
LOCK_STATUS_SELECTOR="[data-testid='lock-status']"

# 預設支援 4~6 碼 OTP。若你的信件格式不同請改這裡。
OTP_CODE_REGEX="\\b(\\d{4,6})\\b"

# 判斷狀態用字串，可依你的頁面文字調整
STATUS_OPEN_REGEX="(unlocked|open|開門|未上鎖)"
STATUS_CLOSED_REGEX="(locked|closed|關門|上鎖)"

# 單位毫秒
OTP_WAIT_TIMEOUT_MS="90000"
OTP_POLL_INTERVAL_MS="3000"
OTP_MAX_AGE_MS="600000"
SESSION_COOKIE_TTL_SEC="604800"

# Telegram
TELEGRAM_ENABLED="true"
TELEGRAM_BOT_TOKEN="123456789:replace_me"
TELEGRAM_CHAT_ID="-1001234567890"

# 收到 OTP 郵件後要轉寄給你原始信箱時可設定，不需要可留空
OTP_FORWARD_TO=""
